# O4AA Knowledge Hub — Environment Variables
# Copy to .env.local and fill in values

LITELLM_API_URL=https://llm.atko.ai
LITELLM_API_KEY=your_litellm_key_here
CLAUDE_MODEL=claude-4-6-sonnet
# Image generation model — check GET /v1/models for available options on your proxy
# titan-image-generator-v2 is available on llm.atko.ai
GEMINI_MODEL=titan-image-generator-v2
FIRECRAWL_API_KEY=your_firecrawl_key_here
